<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:location1="clr-namespace:DotnetPackaging.Exe.Installer.Flows.Installation.Wizard.Location"
             mc:Ignorable="d" 
             x:Class="DotnetPackaging.Exe.Installer.Flows.Installation.Wizard.Location.LocationView"
             x:DataType="location1:ILocationViewModel">
    <Design.DataContext>
        <location1:LocationViewModelMock />
    </Design.DataContext>

    <StackPanel Margin="16 12 16 4" Spacing="8" VerticalAlignment="Center">
        <TextBlock Text="Select the installation folder" FontWeight="Bold"/>
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox
                ToolTip.Tip="{Binding InstallDirectory}"
                Text="{Binding InstallDirectory, Mode=TwoWay}"  />
            <EnhancedButton Grid.Column="1"
                            Content="Browse…"
                            Command="{Binding Browse}" />
        </Grid>
    </StackPanel>
</UserControl>
